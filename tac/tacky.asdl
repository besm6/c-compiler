module TAC {
    Program = (TopLevel* decls)

    TopLevel = Function(identifier name, bool global, identifier* params,
                        StaticLocal* static_locals, Instruction* body)
             | StaticVariable(identifier name, bool global, Type typ, StaticInit* init_list)
             | StaticConstant(identifier name, Type typ, StaticInit init)

    -- A block-scope static variable, emitted inside its owning function's module.
    StaticLocal = (identifier name, Type typ, StaticInit* init_list)

    Instruction = Return(Val? src)
                | SignExtend(Val src, Val dst)
                | Truncate(Val src, Val dst)
                | ZeroExtend(Val src, Val dst)
                | DoubleToInt(Val src, Val dst)
                | DoubleToUInt(Val src, Val dst)
                | IntToDouble(Val src, Val dst)
                | UIntToDouble(Val src, Val dst)
                | FloatToDouble(Val src, Val dst)
                | DoubleToFloat(Val src, Val dst)
                | IntToFloat(Val src, Val dst)
                | UIntToFloat(Val src, Val dst)
                | FloatToInt(Val src, Val dst)
                | FloatToUInt(Val src, Val dst)
                | LongDoubleToInt(Val src, Val dst)
                | LongDoubleToUInt(Val src, Val dst)
                | IntToLongDouble(Val src, Val dst)
                | UIntToLongDouble(Val src, Val dst)
                | LongDoubleToDouble(Val src, Val dst)
                | DoubleToLongDouble(Val src, Val dst)
                | LongDoubleToFloat(Val src, Val dst)
                | FloatToLongDouble(Val src, Val dst)
                | PtrToCharPtr(Val src, Val dst)
                | CharPtrToPtr(Val src, Val dst)
                | Unary(UnaryOperator op, Val src, Val dst)
                | Binary(BinaryOperator op, Val src1, Val src2, Val dst)
                | Copy(Val src, Val dst)
                | GetAddress(Val src, Val dst)
                | GetAddressByte(Val src, Val dst)   -- &char object → char*/void* fat pointer (offset_enc 0)
                | GetAddressDecay(Val src, Val dst)  -- char-array/string decay → fat pointer (offset_enc 5)
                | Load(Val src_ptr, Val dst)
                | LoadByte(Val src_ptr, Val dst)     -- dereference a single byte through a fat pointer
                | Store(Val src, Val dst_ptr)
                | StoreByte(Val src, Val dst_ptr)    -- store a single byte through a fat pointer
                | AddPtr(Val ptr, Val index, int scale, Val dst)
                | CopyToOffset(Val src, identifier dst, int offset)
                | CopyByteToOffset(Val src, identifier dst, int offset)   -- sub-word packed char member (byte RMW)
                | CopyFromOffset(identifier src, int offset, Val dst)
                | CopyByteFromOffset(identifier src, int offset, Val dst) -- sub-word packed char member (byte extract)
                | Jump(identifier target)
                | JumpIfZero(Val condition, identifier target)
                | JumpIfNotZero(Val condition, identifier target)
                | Label(identifier name)
                | FunCall(identifier fun_name, Val* args, Val? dst)
                | AllocateLocal(identifier name, int size, int alignment) -- size/alignment in target bytes

    Val = Constant(Const val)
        | Var(identifier name)

    UnaryOperator = Complement | Negate | Not | NegateUnsigned | NegateDouble

    BinaryOperator = Add | Subtract | Multiply | Divide | Remainder | Equal | NotEqual
                   | LessThan | LessOrEqual | GreaterThan | GreaterOrEqual
                   | BitwiseAnd | BitwiseOr | BitwiseXor | LeftShift | RightShift
                   | DivideUnsigned | RemainderUnsigned
                   | LessThanUnsigned | LessOrEqualUnsigned
                   | GreaterThanUnsigned | GreaterOrEqualUnsigned
                   | RightShiftLogical
                   | AddUnsigned | SubtractUnsigned | MultiplyUnsigned
                   | AddDouble | SubtractDouble | MultiplyDouble | DivideDouble

    Type = Char | SChar | UChar | Short | UShort | Int | Long | LongLong | UInt | ULong | ULongLong
         | Float | Double | LongDouble | Void
         | FunType(Type* params, Type ret)
         | Pointer(Type referenced)
         | Array(Type element, int size)
         | Structure(identifier tag)

    StaticInit = CharInit(int val) | UCharInit(int val)
               | ShortInit(int val) | UShortInit(int val)
               | IntInit(int val) | UIntInit(int val)
               | LongInit(long val) | ULongInit(long val)
               | FloatInit(float val) | DoubleInit(double val) | LongDoubleInit(long double val) | ZeroInit(int bytes)
               | StringInit(string val, bool null_terminated)
               | PointerInit(string name)

    Const = ConstInt(int val) | ConstLong(long val) | ConstLongLong(long long val)
          | ConstUInt(int val) | ConstULong(long val) | ConstULongLong(unsigned long long val)
          | ConstFloat(float val) | ConstDouble(double val) | ConstLongDouble(long double val) | ConstChar(int val) | ConstUChar(int val)
}
