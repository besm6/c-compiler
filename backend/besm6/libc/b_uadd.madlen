    b/uadd: ,name,
c
c Add two 48-bit unsigned integers, modulo 2^48: a+b.
c Pop two values from stack, push result back.
c Value a is in stack, value b on accumulator.
c
            ,ntr, 8+3
            ,uza, b*large           . jump when B[48] = 1
         15 ,xts, -2                . push B on stack, extract A
            ,ntr, 8+3
            ,uza, a*large           . jump when A[48] = 1
c
         15 ,arx,                   . add A[47:1] + B[47:1]
         15 ,utm, -1                . drop A from stack
         13 ,uj,
c
   b*large: ,bss,                   . bit B[48] == 1
            ,aex, =:4               . clear bit 48 of B
         15 ,xts, -2                . push B on stack, extract A
            ,ntr, 8+3
            ,uza, ab*large          . jump when A[48] = 1
         15 ,arx,                   . add A[47:1] + B[47:1]
            ,aex, =:4               . restore bit 48 contribution
         15 ,utm, -1                . drop A from stack
         13 ,uj,
c
   a*large: ,bss,                   . bit A[48] == 1, bit B[48] == 0
            ,aex, =:4               . clear bit 48 of A
         15 ,arx,                   . add A[47:1] + B[47:1]
            ,aex, =:4               . restore bit 48 contribution
         15 ,utm, -1                . drop A from stack
         13 ,uj,
c
  ab*large: ,bss,                   . bit A[48] == 1, bit B[48] == 1
            ,aex, =:4               . clear bit 48 of A
         15 ,arx,                   . add A[47:1] + B[47:1]
         15 ,utm, -1                . drop A from stack
         13 ,uj,
            ,end,
