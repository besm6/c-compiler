      b/uge: ,name,
c
c Unsigned greater than or equal.
c Pop two values from stack, push result back.
c
    b/true: ,subp,
         15 ,aex,                   . A ^ B
         15 ,atx,                   . push to stack
            ,yta,                   . get B from RMR
         15 ,apx,                   . pop A^B from stack, pack by B
            ,asn, 64+47             . get bit 48
            ,aex, b/true            . invert
         13 ,uj,
            ,end,
